# NexusTrade Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to Git

# Admin Token - required as a "server configured" flag for all API functions
# Minimum 32 characters. Use a cryptographically random value.
# Example: openssl rand -hex 32
ADMIN_TOKEN=your_secret_admin_token_here_min_32_chars

# Master Admin Wallet - the wallet address that must be entered as the first
# step of the admin dashboard login (Step 0). Only this address unlocks the
# login flow. Must be the full, connected master account wallet (not a watch
# address). Example below is a TRON (TRC20) address format.
ADMIN_WALLET=TKPD7NTVYDMAA727tNrDjNSuvxsVJjtyyZ

# Master Admin Email - the email address that will receive OTP login codes
# This is the master account for the admin backend
ADMIN_EMAIL=your_admin_email@example.com

# Gmail sending credentials (used to send OTP codes to ADMIN_EMAIL)
# GMAIL_USER    - the Gmail address used to send emails (can be same as ADMIN_EMAIL)
# GMAIL_APP_PASSWORD - a Gmail App Password (NOT your normal Gmail password)
#
# How to generate a Gmail App Password:
#   1. Go to https://myaccount.google.com/security
#   2. Enable 2-Step Verification if not already enabled
#   3. Go to "App passwords" (under "How you sign in to Google")
#   4. Select "Mail" and your device, then click "Generate"
#   5. Copy the 16-character password shown and paste it below
GMAIL_USER=your_gmail_address@gmail.com
GMAIL_APP_PASSWORD=your_16_char_gmail_app_password_here

# Application environment
NODE_ENV=development

# ── Ethereum / EVM Network Configuration ──────────────────────────────────────
# The chain that the frontend prompts users to connect to when they use MetaMask
# or another EVM browser wallet.
#
# APP_URL  – public URL of the app (used in SIWE messages; defaults to https://nexustrade.website)
APP_URL=https://nexustrade.website
#
# To target a testnet (Sepolia) instead of mainnet, add a data-eth-network="sepolia"
# attribute to the <html> element in index.html. No extra backend env var is needed.
# Supported values: mainnet (default) | sepolia
#
# RPC endpoints used for chain-add prompts in wallet_addEthereumChain:
#   Mainnet: https://cloudflare-eth.com  (public, no key required)
#   Sepolia: https://rpc.sepolia.org     (public, no key required)
#
# If you want to use a private RPC (e.g., Infura, Alchemy), update ETH_CHAINS
# in index.html with your endpoint and key.

# Enterprise settings (optional)
# SESSION_TTL_HOURS=1
# RATE_LIMIT_MAX_REQUESTS=30
