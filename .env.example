# NexusTrade Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to Git

# Admin Token - required for all admin write operations
# Set this in Netlify: Site Settings -> Build & Deploy -> Environment Variables
# Minimum 32 characters. Use a cryptographically random value.
# Example: openssl rand -hex 32
ADMIN_TOKEN=your_secret_admin_token_here_min_32_chars

# Application environment
NODE_ENV=development

# Enterprise settings (optional)
# SESSION_TTL_HOURS=1
# RATE_LIMIT_MAX_REQUESTS=30
