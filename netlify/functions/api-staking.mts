// netlify/functions/api-staking.mts\n\nimport { v4 as uuidv4 } from 'uuid';\n\ninterface Stake {\n    id: string;\n    user: string;\n    amount: number;\n    timestamp: number;\n}\n\nconst stakes: Stake[] = [];\n\nexport const handler = async (event) => {\n    const { action, user, amount } = JSON.parse(event.body);\n\n    switch (action) {\n        case 'stake':\n            return stake(user, amount);\n        case 'unstake':\n            return unstake(user);\n        case 'admin-complete':\n            return adminComplete();\n        case 'admin-cancel':\n            return adminCancel();\n        default:  \n            return { statusCode: 400, body: JSON.stringify({ message: 'Invalid action.' }) };\n    }\n};\n\nconst stake = (user: string, amount: number) => {\n    const id = uuidv4();\n    const timestamp = Date.now();\n    \n    if (amount <= 0) {\n        return { statusCode: 400, body: JSON.stringify({ message: 'Invalid stake amount.' }) };\n    }\n\n    stakes.push({ id, user, amount, timestamp });\n    return { statusCode: 200, body: JSON.stringify({ message: 'Staked successfully', id }) };\n};\n\nconst unstake = (user: string) => {\n    const index = stakes.findIndex(stake => stake.user === user);\n    \n    if (index === -1) {\n        return { statusCode: 404, body: JSON.stringify({ message: 'No stake found for user.' }) };\n    }\n    \n    const [unstaked] = stakes.splice(index, 1);\n    const profit = calculateProfit(unstaked);\n    \n    return { statusCode: 200, body: JSON.stringify({ message: 'Unstaked successfully', profit }) };\n};\n\nconst calculateProfit = (stake: Stake) => {\n    const duration = Date.now() - stake.timestamp;\n    const profit = (stake.amount * duration) / (1000 * 60 * 60 * 24); // Example calculation\n    return profit;\n};\n\nconst adminComplete = () => {\n    // Logic for admin completing staking (e.g., distribute profits)\n    return { statusCode: 200, body: JSON.stringify({ message: 'Staking completed by admin.' }) };\n};\n\nconst adminCancel = () => {\n    // Logic for admin canceling staking (e.g., refund users)\n    stakes.length = 0; // Clear all stakes\n    return { statusCode: 200, body: JSON.stringify({ message: 'Staking canceled by admin. All stakes cleared.' }) };\n};\n