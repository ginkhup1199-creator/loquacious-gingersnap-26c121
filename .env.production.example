# NexusTrade Admin Backend – Production Environment Variables Template
#
# USAGE
# -----
# 1. Copy this file:  cp .env.production.example .env.production
# 2. Fill in every value below with your real credentials.
# 3. NEVER commit .env.production to Git (it is already in .gitignore).
# 4. In Netlify: paste each variable into Site Settings → Environment Variables.
# 5. In Railway: paste each variable into the Railway project Variables panel.

# ── Required: Admin Authentication ───────────────────────────────────────────

# Random secret that proves the server is configured.
# All API write functions check for this at startup.
# Generate with:  openssl rand -hex 32
ADMIN_TOKEN=CHANGE_ME_run_openssl_rand_hex_32

# The email address that will receive 2-step OTP login codes.
# This is the master admin account — keep it private.
ADMIN_EMAIL=your-admin@example.com

# ── Required: Gmail SMTP (OTP delivery) ──────────────────────────────────────

# Gmail address used to SEND the OTP emails (can equal ADMIN_EMAIL).
GMAIL_USER=your-sender@gmail.com

# Gmail App Password (16 chars, no spaces) — NOT your regular Gmail password.
# Generate at: https://myaccount.google.com/apppasswords
#   1. Enable 2-Step Verification on the Google account.
#   2. Go to App passwords → Select "Mail" → Generate.
#   3. Paste the 16-character code here.
GMAIL_APP_PASSWORD=CHANGE_ME_16_char_app_password

# ── Application Runtime ───────────────────────────────────────────────────────

NODE_ENV=production

# Optional: shown in /api/health response for release tracking
APP_VERSION=1.0.0

# ── Optional: Session & Rate Limiting Tuning ─────────────────────────────────

# Session lifetime in milliseconds (default: 3600000 = 1 hour)
# SESSION_TTL_MS=3600000

# OTP expiry in milliseconds (default: 600000 = 10 minutes)
# OTP_TTL_MS=600000

# Max OTP verification attempts before the code is invalidated (default: 5)
# OTP_MAX_ATTEMPTS=5

# Rate limit: max requests per window per IP (default: 30)
# RATE_LIMIT_MAX=30

# Rate limit: window in milliseconds (default: 60000 = 1 minute)
# RATE_LIMIT_WINDOW_MS=60000

# ── Optional: Netlify Blobs (auto-injected in Netlify, needed for Railway) ───

# When running outside Netlify (e.g. Railway) you need a site ID and token
# so the @netlify/blobs client can connect to the Netlify Blobs API.
#
# Find these in Netlify:
#   Site ID   → Site settings → General → Site ID
#   Token     → User settings → Applications → Personal access tokens
#
# NETLIFY_SITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# NETLIFY_TOKEN=your_netlify_personal_access_token_here

# ── Optional: CORS ───────────────────────────────────────────────────────────

# Comma-separated list of allowed frontend origins (default: allow all)
# ALLOWED_ORIGINS=https://nexustrade.website,https://www.nexustrade.website,https://admin.nexustrade.website
