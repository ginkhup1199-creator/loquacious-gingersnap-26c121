# NexusTrade Production Environment Variables
# Copy to .env.production and fill in real production values
# NEVER commit this file to Git

# Admin Token - required as a "server configured" flag for all API functions
# Requirements: minimum 32 characters, randomly generated, never shared
# Generate: openssl rand -hex 32
ADMIN_TOKEN=your_production_admin_token_here_min_32_chars

# Master Admin Email - receives OTP login codes (master account)
ADMIN_EMAIL=your_admin_email@example.com

# Gmail sending credentials
# GMAIL_USER    - Gmail address used to send OTP emails
# GMAIL_APP_PASSWORD - Gmail App Password (NOT your normal password)
# Generate at: https://myaccount.google.com/apppasswords
GMAIL_USER=your_gmail_address@gmail.com
GMAIL_APP_PASSWORD=your_16_char_gmail_app_password_here

# Application environment
NODE_ENV=production

# Enterprise security configuration
# SESSION_TTL_HOURS=1          # Admin session lifetime (default: 1 hour)
# RATE_LIMIT_MAX_REQUESTS=30   # Per-IP requests per minute (default: 30)
